<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="Net Conect"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.NetConect"
        android:usesCleartextTraffic="true">

        <activity android:name="com.netconect.app.ui.StockProductsActivity" />
        <activity android:name="com.netconect.app.ui.EntryActivity" />
        <activity android:name="com.netconect.app.ui.BatchMoveActivity" />
        <activity android:name="com.netconect.app.ui.SettingsActivity" />
        <activity android:name="com.netconect.app.ui.HistoryActivity" />
        <activity android:name="com.netconect.app.ui.MoveActivity" />

        <!-- novas telas -->
        <activity android:name="com.netconect.app.ui.SecondReceiptActivity" />
        <activity android:name="com.netconect.app.ui.FinalizedBatchesActivity" />

        <activity android:name="com.netconect.app.ui.MainActivity" />

        <activity
            android:name="com.netconect.app.ui.LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>
