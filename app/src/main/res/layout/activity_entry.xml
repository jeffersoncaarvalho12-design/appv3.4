<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrada de equipamentos"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/green_dark" />

        <Spinner
            android:id="@+id/spinnerEntryMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinnerEntryProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/etEntrySerial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Serial ou MAC" />

        <EditText
            android:id="@+id/etEntrySerials"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="Cole vários seriais/MACs, um por linha"
            android:inputType="textMultiLine"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etEntryQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Quantidade"
            android:inputType="number"
            android:text="1"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etEntryLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Local" />

        <EditText
            android:id="@+id/etEntryNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Observação" />

        <Button
            android:id="@+id/btnEntryScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Escanear pela câmera"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/btn_scanner" />

        <Button
            android:id="@+id/btnEntrySubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Registrar entrada"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/btn_entry" />

        <ProgressBar
            android:id="@+id/progressEntry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
