<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/green_light">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lotes finalizados"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/green_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Buscar por ID, OS, técnico ou data"
        android:textColor="@color/text_dark" />

    <EditText
        android:id="@+id/etSearchBatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="Ex: 21, Erick, 13/03/2026, 35462"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnSearchBatches"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:text="Buscar lotes"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/green_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Toque para abrir cupom 80mm. Pressione e segure para abrir A4."
        android:textColor="#607D8B" />

    <ListView
        android:id="@+id/listFinalizedBatches"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:dividerHeight="10dp" />

</LinearLayout>
