<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Net Conect"
                android:textColor="@color/green_dark"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Controle de estoque"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>

            <!-- linha 1 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoScanner"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Scanner"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/btn_scanner"/>

                <Button
                    android:id="@+id/btnGoEntry"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Entrada"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/btn_entry"/>

            </LinearLayout>

            <!-- linha 2 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoExit"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Saída"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/btn_exit"/>

                <Button
                    android:id="@+id/btnGoBatch"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Lote"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/btn_batch"/>

            </LinearLayout>

            <!-- linha 3 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoStock"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Estoque"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#00897B"/>

                <Button
                    android:id="@+id/btnGoHistory"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Histórico"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/btn_history"/>

            </LinearLayout>

            <!-- NOVA LINHA -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoSecondReceipt"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="2ª via recibo"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#374151"/>

                <Button
                    android:id="@+id/btnGoFinalizedBatches"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Lotes finalizados"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#0F766E"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnGoSettings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="Configurações"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/btn_settings"/>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
