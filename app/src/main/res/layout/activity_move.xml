<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Movimentação de equipamento"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etBarcode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Serial / MAC / modelo"
            android:background="@android:drawable/edit_text"
            android:padding="10dp" />

        <Button
            android:id="@+id/btnSearchItem"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Buscar"
            android:layout_marginTop="6dp"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnScanMove"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Escanear pela câmera"
            android:layout_marginTop="6dp"
            android:backgroundTint="#0288D1"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/tvItemStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status atual"
            android:layout_marginBottom="10dp" />

        <Spinner
            android:id="@+id/spinnerMovement"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <Spinner
            android:id="@+id/spinnerTechnicianMove"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spinnerReasonMove"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etLocation"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Localização"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Observação"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnSendMove"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Confirmar movimentação"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_marginTop="12dp" />

        <ProgressBar
            android:id="@+id/progressMove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="10dp" />

    </LinearLayout>

</ScrollView>
