<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2ª via de recibo"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#166534" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informe o ID do lote para reabrir o recibo"
            android:layout_marginTop="8dp"
            android:textColor="#4B5563" />

        <EditText
            android:id="@+id/etSecondReceiptBatchId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="ID do lote"
            android:inputType="number"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnOpenThermal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="Abrir cupom 80mm"
            android:textColor="#FFFFFF"
            android:backgroundTint="#111827" />

        <Button
            android:id="@+id/btnOpenA4"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Abrir recibo A4"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB" />

    </LinearLayout>
</ScrollView>
