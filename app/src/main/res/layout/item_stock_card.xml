<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imgCardProduct"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="Foto do produto"
            android:scaleType="centerCrop"
            android:src="@android:drawable/sym_def_app_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCardProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produto"
                android:textColor="@color/green_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCardQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Disponível: 0"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCardCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Categoria"
                android:textColor="#607D8B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvCardRef"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="REF"
                android:textColor="#607D8B"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnCardPhoto"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:text="Foto"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#1565C0" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
